{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "California District Mapper",
  "version": "0.1.0",
  "identifier": "com.chnnick.district-mapper",
  "build": {
    "beforeDevCommand": "npm --prefix ../frontend run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm --prefix ../frontend run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "externalBin": [
      "binaries/district-mapper-backend"
    ]
  }
}
